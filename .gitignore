# Research artifacts — generated during runs, not tracked in git
runs/

# Raw papers — often large PDFs, not worth tracking in git
papers/raw/

# Generated paper database — derived from raw, not source-controlled
# Templates and index remain tracked
papers/overview/*.md
papers/condensed/*.md
!papers/overview/_template.md
!papers/condensed/_template.md
papers/index.md

# Research target — symlink or external path for real projects (not part of this repo)
# Commented out here so the dummy example in research_target/ is tracked.
# Uncomment when pointing at your own codebase:
# research_target/

# config/ - not tracked to preserve dummy example config.
config/*

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# OS
.DS_Store
Thumbs.db
